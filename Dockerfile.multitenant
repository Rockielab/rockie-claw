# syntax=docker/dockerfile:1.19
#
# Per-tenant runtime image for Rockielab / Pebble ML.
#
# Three modes are selected at boot via the MODE env var:
#   - subscription : run the official @anthropic-ai/claude-code (and @openai/codex)
#                    binary against the tenant's Pro/Max OAuth session.
#   - byok         : run the OpenClaw gateway against the tenant's API key.
#   - open-weights : run the OpenClaw gateway against a platform-hosted
#                    open-weights endpoint (cerebras / chutes / etc).
#
# The image bundles the OpenClaw gateway build (same stages as the existing
# Dockerfile), the official claude / codex CLIs, Python 3.12, and the
# platform-skills overlay translated into ~/.claude/ + ~/.codex/.
#
# Build with scripts/build-multitenant.sh, which sets the right build-args
# and the platform-skills build-context.

ARG OPENCLAW_EXTENSIONS=""
ARG OPENCLAW_BUNDLED_PLUGIN_DIR=extensions
ARG OPENCLAW_NODE_BOOKWORM_IMAGE="node:24-bookworm@sha256:3a09aa6354567619221ef6c45a5051b671f953f0a1924d1f819ffb236e520e6b"
ARG OPENCLAW_NODE_BOOKWORM_SLIM_IMAGE="node:24-bookworm-slim@sha256:e8e2e91b1378f83c5b2dd15f0247f34110e2fe895f6ca7719dbb780f929368eb"
ARG OPENCLAW_BUN_IMAGE="oven/bun:1.3.13@sha256:87416c977a612a204eb54ab9f3927023c2a3c971f4f345a01da08ea6262ae30e"

# ── Stage 1: OpenClaw extension package.json gather ────────────────
FROM ${OPENCLAW_NODE_BOOKWORM_IMAGE} AS ext-deps
ARG OPENCLAW_EXTENSIONS
ARG OPENCLAW_BUNDLED_PLUGIN_DIR
RUN --mount=type=bind,source=${OPENCLAW_BUNDLED_PLUGIN_DIR},target=/tmp/${OPENCLAW_BUNDLED_PLUGIN_DIR},readonly \
    mkdir -p /out && \
    for ext in $OPENCLAW_EXTENSIONS; do \
      if [ -f "/tmp/${OPENCLAW_BUNDLED_PLUGIN_DIR}/$ext/package.json" ]; then \
        mkdir -p "/out/$ext" && \
        cp "/tmp/${OPENCLAW_BUNDLED_PLUGIN_DIR}/$ext/package.json" "/out/$ext/package.json"; \
      fi; \
    done

# ── Stage 2: Build OpenClaw ────────────────────────────────────────
FROM ${OPENCLAW_BUN_IMAGE} AS bun-binary
FROM ${OPENCLAW_NODE_BOOKWORM_IMAGE} AS build
ARG OPENCLAW_BUNDLED_PLUGIN_DIR

COPY --from=bun-binary /usr/local/bin/bun /usr/local/bin/bun
RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml .npmrc ./
COPY openclaw.mjs ./
COPY ui/package.json ./ui/package.json
COPY patches ./patches
COPY scripts/postinstall-bundled-plugins.mjs scripts/preinstall-package-manager-warning.mjs scripts/prepare-git-hooks.mjs scripts/npm-runner.mjs scripts/windows-cmd-helpers.mjs ./scripts/
COPY scripts/lib/package-dist-imports.mjs ./scripts/lib/package-dist-imports.mjs

COPY --from=ext-deps /out/ ./${OPENCLAW_BUNDLED_PLUGIN_DIR}/

RUN --mount=type=cache,id=openclaw-pnpm-store,target=/root/.local/share/pnpm/store,sharing=locked \
    NODE_OPTIONS=--max-old-space-size=2048 pnpm install --frozen-lockfile

RUN set -eux; \
    for attempt in 1 2 3 4 5; do \
      if find /app/node_modules -name "matrix-sdk-crypto*.node" 2>/dev/null | grep -q .; then \
        exit 0; \
      fi; \
      node /app/node_modules/@matrix-org/matrix-sdk-crypto-nodejs/download-lib.js || true; \
      sleep $((attempt * 2)); \
    done; \
    find /app/node_modules -name "matrix-sdk-crypto*.node" 2>/dev/null | grep -q . || \
      (echo "ERROR: matrix-sdk-crypto native addon missing after retries" >&2 && exit 1)

COPY --exclude=apps/broker --exclude=apps/broker/** . .

RUN for dir in /app/${OPENCLAW_BUNDLED_PLUGIN_DIR} /app/.agent /app/.agents; do \
      if [ -d "$dir" ]; then \
        find "$dir" -type d -exec chmod 755 {} +; \
        find "$dir" -type f -exec chmod 644 {} +; \
      fi; \
    done

RUN timeout --kill-after=10s 120s node scripts/bundle-a2ui.mjs || \
    (echo "A2UI bundle: creating stub (non-fatal)" && \
     mkdir -p extensions/canvas/src/host/a2ui && \
     echo "/* A2UI bundle unavailable in this build */" > extensions/canvas/src/host/a2ui/a2ui.bundle.js && \
     echo "stub" > extensions/canvas/src/host/a2ui/.bundle.hash && \
     rm -rf extensions/canvas/src/host/a2ui-app vendor/a2ui apps/shared/OpenClawKit/Tools/CanvasA2UI)
RUN pnpm build:docker
ENV OPENCLAW_PREFER_PNPM=1
RUN pnpm ui:build
RUN pnpm qa:lab:build

# ── Stage 3: Prune OpenClaw runtime assets ─────────────────────────
FROM build AS runtime-assets
ARG OPENCLAW_EXTENSIONS
ARG OPENCLAW_BUNDLED_PLUGIN_DIR
RUN printf 'packages:\n  - .\n  - ui\n' > /tmp/pnpm-workspace.runtime.yaml && \
    for ext in $OPENCLAW_EXTENSIONS; do \
      printf '  - %s/%s\n' "$OPENCLAW_BUNDLED_PLUGIN_DIR" "$ext" >> /tmp/pnpm-workspace.runtime.yaml; \
    done && \
    cp /tmp/pnpm-workspace.runtime.yaml pnpm-workspace.yaml && \
    CI=true NPM_CONFIG_FROZEN_LOCKFILE=false pnpm prune --prod && \
    node scripts/postinstall-bundled-plugins.mjs && \
    find dist -type f \( -name '*.d.ts' -o -name '*.d.mts' -o -name '*.d.cts' -o -name '*.map' \) -delete && \
    node scripts/check-package-dist-imports.mjs /app

# ── Stage 4: Skill assembly (translate platform-skills layout) ─────
# `skills` build-context is bound into this stage so the host path is
# never baked into the image. See scripts/build-multitenant.sh.
FROM debian:bookworm-slim AS skills-assembly
RUN --mount=type=cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
      bash coreutils ca-certificates rsync && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /work
COPY --from=skills . /work/platform-skills/
COPY overlay/multitenant/assemble-skills.sh /usr/local/bin/assemble-skills.sh
RUN chmod +x /usr/local/bin/assemble-skills.sh && \
    mkdir -p /work/home && \
    /usr/local/bin/assemble-skills.sh /work/platform-skills /work/home

# ── Stage 4b: Build the PTY-WebSocket broker (Go) ──────────────────
# Small static binary that bridges xterm.js <-> claude/codex/bash PTYs.
# See apps/broker/README.md for the wire protocol.
FROM --platform=$BUILDPLATFORM golang:1.23-bookworm AS broker-build
ARG TARGETOS
ARG TARGETARCH
WORKDIR /src
COPY apps/broker/go.mod apps/broker/go.sum ./
RUN --mount=type=cache,id=broker-go-mod,target=/go/pkg/mod,sharing=locked \
    go mod download
COPY apps/broker/ ./
RUN --mount=type=cache,id=broker-go-mod,target=/go/pkg/mod,sharing=locked \
    --mount=type=cache,id=broker-go-build,target=/root/.cache/go-build,sharing=locked \
    CGO_ENABLED=0 GOOS=${TARGETOS:-linux} GOARCH=${TARGETARCH:-amd64} GOFLAGS="-p=1" \
      go build -ldflags="-s -w" -o /out/broker .

# ── Stage 4c: Assemble the nugget (Goose) harness via FETCH ─────────
# The nugget research harness is the SAME artifact OSS users get: we
# FETCH it from the canonical repo (Rockielab/rockie-nugget) at a pinned
# SHA and run its OWN install.sh to lay the overlay down — config-only,
# so the platform bake ≡ a local `./install.sh`. This deliberately
# REPLACES the stale committed-snapshot approach (PR #108): a vendored
# snapshot drifts from rockie-nugget main; a SHA-pinned fetch cannot.
#
# Two pinned inputs:
#   - NUGGET_OVERLAY_REF : the rockie-nugget commit the overlay comes from.
#   - NUGGET_GOOSE_URL + NUGGET_GOOSE_SHA256 : the released Goose runtime
#     binary (glibc-2.36, matches the bookworm-slim final base). Defaults
#     are HARDCODED to the rockie-nugget release so NO workflow build-arg
#     is needed — the image always builds with zero CI changes.
#
# The Goose binary is fetched here (not in the slim final stage) so the
# final image stays free of build-time curl/tar churn; the staged tree is
# COPYed in below.
FROM debian:bookworm-slim AS nugget-overlay
ARG NUGGET_OVERLAY_REF=13ae0cde60fe8df21f48d44a3727587e82fe3eb9
ARG NUGGET_GOOSE_URL="https://github.com/Rockielab/rockie-nugget/releases/download/nugget-goose-v1.38.0-glibc236/goose"
ARG NUGGET_GOOSE_SHA256="489391da775fcdafbda8bf2322b15580938f3fdad243cc8e7d03bc1e0530be98"
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates curl tar python3 && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Stage at the SAME absolute paths the final image uses, so install.sh's
# generated config.yaml (which embeds absolute paths to the MCP server +
# contract) resolves identically after COPY. The repo checkout lives at
# /opt/nugget/src (outside /home/runtime so a tenant volume mount can't
# hide it), and the per-user XDG tree is staged at /stage/home/runtime →
# hydrated into $HOME at boot by the entrypoint (mirrors home-bundle).
WORKDIR /build
RUN set -eux; \
    SRC=/opt/nugget/src; \
    STAGE_HOME=/stage/home/runtime; \
    mkdir -p "$SRC" "$STAGE_HOME/.local/bin"; \
    # 1. Fetch the rockie-nugget source at the pinned SHA (public codeload,
    #    so no auth/token is needed inside the build). The SHA in the URL is
    #    the pin — a different ref yields a different tarball.
    if curl -fSL --retry 3 \
         "https://codeload.github.com/Rockielab/rockie-nugget/tar.gz/${NUGGET_OVERLAY_REF}" \
         -o /build/nugget-src.tar.gz; then \
      tar -xzf /build/nugget-src.tar.gz -C "$SRC" --strip-components=1; \
      # 2. Pre-stage the released Goose runtime binary so install.sh verifies +
      #    installs it (sha256 pin). Same binary a local user fetches; it lives
      #    at the final image path so the launcher + config resolve it there.
      curl -fSL --retry 3 "${NUGGET_GOOSE_URL}" -o /build/goose; \
      echo "${NUGGET_GOOSE_SHA256}  /build/goose" | sha256sum -c -; \
      install -m 0755 /build/goose "$STAGE_HOME/.local/bin/goose"; \
      # 3. Run rockie-nugget's OWN installer with platform target dirs. Same
      #    installer a local user runs → platform ≡ local. The binary is already
      #    staged + sha-correct so install.sh's verify short-circuits the fetch.
      #    REPO_ROOT = dirname(install.sh) = $SRC, so config.yaml embeds
      #    /opt/nugget/src/{mcp,contract}/... — image-stable, volume-safe.
      # install.sh's LAST step (writing its own `nugget` launcher) trips an
      # `MCP_DIR: unbound variable` under `set -u` in rockie-nugget@<SHA>; it
      # exits non-zero AFTER every overlay/config artifact is already written.
      # We overwrite that launcher anyway (below), so tolerate the trailing
      # failure and instead VERIFY the artifacts we depend on — failing the
      # build only if config.yaml / .goosehints / the goose binary are missing.
      HOME="$STAGE_HOME" \
      XDG_CONFIG_HOME="$STAGE_HOME/.config" \
      NUGGET_BIN_DIR="$STAGE_HOME/.local/bin" \
      NUGGET_WORKSPACE="/home/runtime/.local/share/nugget/workspace" \
      NUGGET_PLUGINS_DIR="$STAGE_HOME/.agents/plugins" \
        bash "$SRC/install.sh" || echo "nugget-overlay: install.sh exited non-zero (trailing launcher bug); verifying artifacts"; \
      test -s "$STAGE_HOME/.config/goose/config.yaml"; \
      grep -q "enabled: true" "$STAGE_HOME/.config/goose/config.yaml"; \
      test -s "$STAGE_HOME/.config/goose/.goosehints"; \
      test -x "$STAGE_HOME/.local/bin/goose"; \
      test -f "$SRC/mcp/research-env-mcp/server.py"; \
      test -d "$SRC/contract/research-env-v1"; \
      # The install.sh `nugget` launcher re-derives goose args (run/login) and
      # would drop the broker's --no-session/--name/--output-format flags. The
      # broker (apps/broker/main.go nuggetChatArgs) already builds the correct
      # goose argv and the entrypoint (wire_nugget_byok_env) already exports the
      # GOOSE_* provider env at PID-1, so the PLATFORM `nugget` is a thin
      # passthrough to goose. Overwrite the launcher install.sh wrote.
      printf '#!/usr/bin/env bash\n# nugget (platform) — thin passthrough to the baked Goose runtime.\n# The broker builds the goose argv; the entrypoint exports GOOSE_* provider env.\nset -euo pipefail\nexec /home/runtime/.local/bin/goose "$@"\n' \
        > "$STAGE_HOME/.local/bin/nugget"; \
      chmod 0755 "$STAGE_HOME/.local/bin/nugget"; \
      printf 'rockie-nugget@%s\n' "${NUGGET_OVERLAY_REF}" \
        > "$STAGE_HOME/.config/goose/.nugget-overlay-ref"; \
    else \
      # 4. Network-unreachable fallback (same defensive pattern #108 used for
      #    the binary): stage a stub `nugget`/`goose` that exits non-zero with a
      #    clear message, so claude/codex/openclaw still build and run.
      echo "nugget-overlay: WARN could not fetch rockie-nugget@${NUGGET_OVERLAY_REF}; baking not-provisioned stub" >&2; \
      mkdir -p "$STAGE_HOME/.config/goose"; \
      for b in goose nugget; do \
        printf '#!/usr/bin/env bash\necho "nugget not provisioned: the rockie-nugget overlay could not be fetched at build time (NUGGET_OVERLAY_REF=%s). Rebuild with network access to https://codeload.github.com/Rockielab/rockie-nugget." >&2\nexit 1\n' \
          "${NUGGET_OVERLAY_REF}" > "$STAGE_HOME/.local/bin/$b"; \
        chmod 0755 "$STAGE_HOME/.local/bin/$b"; \
      done; \
      printf 'not-provisioned (fetch failed at build): %s\n' "${NUGGET_OVERLAY_REF}" \
        > "$STAGE_HOME/.config/goose/.nugget-overlay-ref"; \
    fi

# ── Stage 5: Final multitenant runtime image ───────────────────────
FROM ${OPENCLAW_NODE_BOOKWORM_SLIM_IMAGE}
ARG OPENCLAW_BUNDLED_PLUGIN_DIR

LABEL org.opencontainers.image.title="rockielab-runtime-multitenant" \
  org.opencontainers.image.description="Per-tenant Rockielab / Pebble ML runtime: OpenClaw gateway + official claude/codex CLIs + platform-skills overlay" \
  org.opencontainers.image.licenses="MIT"

ENV DEBIAN_FRONTEND=noninteractive
ENV NODE_ENV=production

# System tooling: git, curl, jq, ssh-client, tmux, python3.12, build basics.
# bookworm ships python3.11; the spec asks for 3.12, so we pull from
# debian-testing only for python (apt pinning prevents unrelated upgrades).
RUN --mount=type=cache,id=openclaw-mt-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=openclaw-mt-apt-lists,target=/var/lib/apt,sharing=locked \
    apt-get update && \
    apt-get install -y --no-install-recommends \
      ca-certificates curl git jq openssh-client tmux \
      procps hostname lsof openssl gnupg \
      python3 python3-pip python3-venv \
      build-essential rsync less && \
    update-ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Optional: try to land python3.12 specifically. bookworm-slim ships 3.11;
# to avoid pulling testing repos and bloating the image, we accept 3.11
# as the system python and additionally install 3.12 only if available
# without changing apt sources. Skills that require 3.12 should declare
# their own venv via uv/pyenv at runtime.
RUN python3 --version

# Install the GitHub CLI (`gh`) — required by the GitHub-repo resource
# feature (rockie-workspace#85 M0). The agent uses `gh pr create` /
# `gh repo clone` under the hood when working on a git_repo source.
# Pulls from cli.github.com per GitHub's documented Debian instructions.
RUN --mount=type=cache,id=openclaw-mt-apt-cache,target=/var/cache/apt,sharing=locked \
    --mount=type=cache,id=openclaw-mt-apt-lists,target=/var/lib/apt,sharing=locked \
    mkdir -p -m 755 /etc/apt/keyrings && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      | tee /etc/apt/keyrings/githubcli-archive-keyring.gpg > /dev/null && \
    chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# Verify gh resolved (cheap fail-fast at build time).
RUN command -v gh && gh --version

# Install the official Hugging Face client (`huggingface_hub` Python pkg
# bundles the `hf` CLI as of v0.36+). Required so the in-tenant agent
# can `hf repos create <namespace>/<name>` (and friends) and use the
# Python SDK directly, once the user pastes a write-scoped HF PAT at
# /settings/connections — the token is staged as the `HF_TOKEN` Fly
# secret by api/routers/connections.py and the CLI/SDK read it on
# next machine restart. fleet-task rockie-workspace#351.
#
# Debian's system-managed Python (PEP 668) refuses an unscoped
# `pip install` outside a venv. `--break-system-packages` is the
# documented escape hatch for container images where the global
# site-packages IS the venv.
RUN python3 -m pip install --no-cache-dir --break-system-packages \
      'huggingface_hub>=0.36.0'

# Lightweight office artifact generators for the productized Excel and
# PowerPoint skills. `rockie-pptagent` is the lean fork wrapper only; it
# must not pull DeepPresenter/model-download/GPU dependencies.
RUN python3 -m pip install --no-cache-dir --break-system-packages \
      'xlsxwriter==3.2.9' \
      'rockie-pptagent @ git+https://github.com/Rockielab/platform-pptx-agent.git@c5200c33c8c36f30a817b36d2dff23e615e06b88'

# Verify both `hf` and the SDK resolved (cheap fail-fast at build time).
RUN command -v hf && hf --version && \
    python3 -c "import huggingface_hub; print('huggingface_hub', huggingface_hub.__version__)" && \
    python3 -c "import xlsxwriter; print('xlsxwriter', xlsxwriter.__version__)" && \
    python3 -c "from rockie_pptagent.wrapper import render_presentation; print(render_presentation)"

# ── rockie-workspace#457: forbid local torch/triton/tensorflow/jax ──
# Tenant Fly machines cannot host inference; GPU work routes via /experiment
# (POST $ROCKIELAB_API_URL/api/jobs/submit). Stub the import paths so any
# `import torch` (etc.) raises with a pointer to the sanctioned path.
# Defence-in-depth alongside role-pre-bash-guard.sh on the orchestrator (#502, #427).
RUN STUB_DIR="$(python3 -c 'import site; print(site.getsitepackages()[0])')" && \
    test -n "$STUB_DIR" && \
    for pkg in torch triton tensorflow jax; do \
      mkdir -p "$STUB_DIR/$pkg" && \
      printf 'raise ImportError("Local %s is forbidden on the Rockie runtime. Dispatch GPU work via $ROCKIELAB_API_URL/api/jobs/submit. See platform-skills/skills/experiment/SKILL.md. (rockie-workspace#457)")\n' "$pkg" > "$STUB_DIR/$pkg/__init__.py"; \
    done && \
    python3 - <<'PY'
import sys
for pkg in ("torch", "triton", "tensorflow", "jax"):
    try:
        __import__(pkg)
    except ImportError as exc:
        if "#457" not in str(exc):
            sys.exit(f"STUB VERIFY FAILED for {pkg}: message missing #457 marker")
        print(f"{pkg} stub OK")
        continue
    sys.exit(f"STUB VERIFY FAILED for {pkg}: import did not raise")
PY

# Install official claude and codex CLIs globally via npm.
# Both are published as npm packages; @anthropic-ai/claude-code is the
# canonical name for the Claude Code CLI and @openai/codex is the canonical
# name for OpenAI's Codex CLI (Apache-2.0).
#
# PIN the claude-code version. An unpinned `@latest` means every image
# rebuild silently bakes whatever claude-code shipped that day, so the CLI
# the broker talks to can change underneath us without a code change — a
# stdin/stream-json contract drift would then strand /chat-pty in prod with
# no diff to point at. The version a tenant runs is owned CENTRALLY (image
# SHA + fleet rollout), so the CLI version must be too. Bump deliberately
# (and re-run the broker real-CLI smoke test) — never via `@latest` drift.
ARG CLAUDE_CODE_VERSION=2.1.178
RUN --mount=type=cache,target=/root/.npm,sharing=locked \
    npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" @openai/codex || \
    (echo "Falling back to per-package install if combined fails" >&2 && \
     npm install -g "@anthropic-ai/claude-code@${CLAUDE_CODE_VERSION}" && \
     npm install -g @openai/codex)

# Verify both binaries resolved (cheap fail-fast at build time).
RUN command -v claude && command -v codex

# Kill the in-machine binary self-updater (#1222 S4 — controlled rollout).
# The version a tenant runs is owned CENTRALLY (bumped via the image SHA and
# pushed by the fleet rollout), NOT self-updated per machine. Per-machine
# self-update fires unpredictably and can hang `claude --version` on a cold
# start, which strands the broker's first spawn.
#   - DISABLE_AUTOUPDATER=1: claude/codex skip their on-launch update check.
#   - CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1: suppress version pings /
#     telemetry that can block startup behind a slow network call.
# Baked into the image so every tenant machine inherits them; the entrypoint
# warm-step relies on these so the warm `--version` can't trigger an update.
ENV DISABLE_AUTOUPDATER=1
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

WORKDIR /app

# Bring in OpenClaw runtime artifacts from the build stages.
COPY --from=runtime-assets /app/dist ./dist
COPY --from=runtime-assets /app/node_modules ./node_modules
COPY --from=runtime-assets /app/package.json ./package.json
COPY --from=runtime-assets /app/patches ./patches
COPY --from=runtime-assets /app/openclaw.mjs ./openclaw.mjs
COPY --from=runtime-assets /app/${OPENCLAW_BUNDLED_PLUGIN_DIR} ./${OPENCLAW_BUNDLED_PLUGIN_DIR}
COPY --from=runtime-assets /app/skills ./openclaw-skills
# OpenClaw's agent workspace bootstrap loads templates from a path
# resolved via resolveWorkspaceTemplateDir (src/agents/workspace-templates.ts):
# the first candidate is `packageRoot/docs/reference/templates`. Copying
# upstream's `docs/` to `./docs` (not `./openclaw-docs`) lets the lookup
# resolve so chat completions don't fail with
# "Missing workspace template: AGENTS.md". The previous `openclaw-docs`
# target was a defensive rename to avoid colliding with a Rockie-side
# docs/ tree — but no Rockie docs/ tree exists inside the image, so the
# rename was unnecessary and broke the BYOK / open-weights chat path.
COPY --from=runtime-assets /app/docs ./docs
COPY --from=runtime-assets /app/qa ./openclaw-qa

# Add a `dist/index.js` shim for the entrypoint's `node /app/dist/index.js gateway`
# convention (OpenClaw's CLI wrapper is openclaw.mjs, not dist/index.js).
RUN if [ ! -f /app/dist/index.js ]; then \
      printf '#!/usr/bin/env node\nimport("/app/openclaw.mjs");\n' > /app/dist/index.js && \
      chmod 755 /app/dist/index.js; \
    fi

# Expose openclaw on PATH.
RUN ln -sf /app/openclaw.mjs /usr/local/bin/openclaw && chmod 755 /app/openclaw.mjs

# ── Tenant runtime user ────────────────────────────────────────────
# Run as a dedicated non-root `runtime` user so ~/.claude/ and ~/.codex/
# are writable and can be remounted with tenant-scoped volumes later.
RUN useradd --create-home --shell /bin/bash --uid 1100 runtime && \
    install -d -m 0755 -o runtime -g runtime \
      /home/runtime/workspace \
      /home/runtime/.claude \
      /home/runtime/.codex

# Drop in the assembled platform-skills overlay outside /home/runtime.
# Tenant Fly apps mount a persistent volume at /home/runtime, so image-layer
# files copied there are hidden on existing tenants. The entrypoint hydrates
# this bundle into the writable volume at boot.
COPY --from=skills-assembly --chown=runtime:runtime /work/home/.claude /opt/rockielab/home-bundle/.claude
COPY --from=skills-assembly --chown=runtime:runtime /work/home/.codex /opt/rockielab/home-bundle/.codex

# Drop in the multitenant overlay files (entrypoint + settings template).
COPY --chown=root:root overlay/multitenant/entrypoint.sh /usr/local/bin/entrypoint.sh
# Per-tenant private user-skill sync (Phase A, S2): fetches the tenant's
# web-authored skills from platform-context and materializes them under
# ~/.claude/skills. Invoked by entrypoint.sh at boot AND by the SessionStart
# hook in settings.json.j2 (so a just-authored skill loads without a restart).
COPY --chown=root:root overlay/multitenant/sync-user-skills.sh /usr/local/bin/sync-user-skills.sh
COPY --chown=runtime:runtime overlay/multitenant/settings.json.j2 /opt/rockielab/home-bundle/.claude/settings.json.j2
COPY --chown=runtime:runtime overlay/multitenant/settings.json.j2 /home/runtime/.claude/settings.json.j2
RUN chmod 755 /usr/local/bin/entrypoint.sh /usr/local/bin/sync-user-skills.sh

# Drop in the git credential helper for GitHub-repo resource access
# (rockie-workspace#85 M0). The helper fetches a short-lived
# installation token from platform-context whenever git asks for one,
# so `git push` against a git_repo source works with no long-lived
# token in the runtime. ``git config --system`` registers it as the
# default credential helper for every shell mcp-rockie spawns.
COPY --chown=root:root overlay/multitenant/runtime/git-credential-rockie.sh \
  /usr/local/bin/git-credential-rockie.sh
RUN chmod 755 /usr/local/bin/git-credential-rockie.sh && \
    git config --system credential.helper /usr/local/bin/git-credential-rockie.sh

# Drop in the env-backed git credential helper for huggingface.co
# (rockie-workspace#575). The helper emits HF_TOKEN from env so plain
# `git clone` / `git push` against huggingface.co authenticate without
# the agent improvising a GIT_ASKPASS bridge. It is registered below.
COPY --chown=root:root overlay/multitenant/runtime/git-credential-hf-env.sh \
  /usr/local/bin/git-credential-hf-env.sh
RUN chmod 755 /usr/local/bin/git-credential-hf-env.sh

# Pre-wire git credential helpers + default identity at BUILD TIME so a
# tenant's agent can `git clone` / `commit` / `push` against github.com and
# huggingface.co with no per-turn improvisation (rockie-workspace#575).
#
# Why build time, not entrypoint.sh: the broker `/spawn` + `/ws` PTY spawn
# the agent shell as **root**, which reads /etc/gitconfig (the --system
# scope), never /home/runtime/.gitconfig (the --global scope of the
# unprivileged `runtime` user). `git config --system` is the right scope —
# but the ENTRYPOINT runs AFTER `USER runtime`, so an entrypoint.sh
# attempting `git config --system` runs as `runtime` and fails
# "Permission denied" writing root-owned /etc/gitconfig. These RUN steps
# run as root (they precede the `USER runtime` directive), so the writes
# land in the image's /etc/gitconfig and persist for every spawned shell.
#
# The helpers are registered UNCONDITIONALLY. They read GH_TOKEN / HF_TOKEN
# at git-invocation time and emit nothing when their token is absent, so a
# BYOK / open-weights tenant that never connected GitHub or Hugging Face is
# unaffected — git simply gets no credential and only fails if it actually
# needs auth. There is no token visible at build time to gate on anyway.
#
# GitHub: replicate `gh auth setup-git`'s effect with explicit --system
# writes for github.com AND gist.github.com — an empty-helper reset (so any
# inherited helper for that host is cleared and ordering is deterministic)
# followed by `!gh auth git-credential` (the bang prefix makes git run it
# as a shell command; `gh` itself reads GH_TOKEN from env). `gh` is
# resolved to an absolute path so the helper does not depend on the agent
# shell's PATH.
RUN for gh_host in github.com gist.github.com; do \
      git config --system --replace-all "credential.https://${gh_host}.helper" "" && \
      git config --system --add "credential.https://${gh_host}.helper" "!$(command -v gh) auth git-credential"; \
    done && \
    git config --system "credential.https://huggingface.co.helper" \
      /usr/local/bin/git-credential-hf-env.sh && \
    git config --system user.name "Rockie Agent" && \
    git config --system user.email "agent@rockielab.com"

# Drop in the PTY-WebSocket broker binary built in stage 4b.
COPY --from=broker-build /out/broker /usr/local/bin/broker
RUN chmod 755 /usr/local/bin/broker

# ── nugget (Goose) harness — fetched from rockie-nugget@SHA, not vendored ──
# The research-env MCP server + contract live at /opt/nugget/src (outside
# /home/runtime so a tenant volume mount can't hide them); config.yaml
# embeds these absolute paths. The per-user XDG overlay (goose binary,
# config.yaml, .goosehints, recipes, memory scaffold, hooks plugin, the
# `nugget`/`goose` launchers) is staged under /opt/rockielab/home-bundle/
# nugget and hydrated into $HOME at boot by entrypoint.sh — exactly how the
# claude/codex skill bundle survives the volume mount. This REPLACES the
# committed snapshot in PR #108: the source of truth is rockie-nugget@SHA,
# so the platform bakes the SAME nugget OSS users get (no drift).
COPY --from=nugget-overlay --chown=runtime:runtime /opt/nugget/src /opt/nugget/src
COPY --from=nugget-overlay --chown=runtime:runtime /stage/home/runtime /opt/rockielab/home-bundle/nugget

# Drop in the rockie-gpu CLI — the agent-facing handle on the GPU
# broker (Phase 5 step 5 of the active MVP plan). Symlinked into
# /usr/local/bin so `rockie-gpu market ...` and other `rockie-gpu`
# commands are available from any cwd inside the runtime.
RUN install -d -m 0755 /opt/rockie-gpu
COPY --chown=root:root overlay/multitenant/rockie-gpu /opt/rockie-gpu/rockie-gpu
RUN chmod 755 /opt/rockie-gpu/rockie-gpu && \
    mkdir -p /usr/local/bin && \
    ln -sf /opt/rockie-gpu/rockie-gpu /usr/local/bin/rockie-gpu

# Sibling CLI for the non-Rockie-GPU rungs of the compute trust ladder
# (MVP step 6): byo_ssh / byo_github / artifact_only. Same shape as
# rockie-gpu — stdlib-only Python, JSON-lines by default, ``--human``
# flips to a kv block for ad-hoc debugging.
RUN install -d -m 0755 /opt/rockie-compute
COPY --chown=root:root overlay/multitenant/rockie-compute /opt/rockie-compute/rockie-compute
RUN chmod 755 /opt/rockie-compute/rockie-compute && \
    ln -sf /opt/rockie-compute/rockie-compute /usr/local/bin/rockie-compute

COPY --chown=root:root overlay/multitenant/rockie /usr/local/bin/rockie
RUN chmod 755 /usr/local/bin/rockie

# rockie-loop daemon (MVP step 9) — the continuous autoresearch loop
# that makes the "Rockie never sleeps" pitch literally true. stdlib-
# only Python, same shape as the rockie-gpu / rockie-compute CLIs.
# Launched by entrypoint.sh as a background process at machine boot.
RUN install -d -m 0755 /opt/rockie-loop
COPY --chown=root:root overlay/multitenant/rockie-loop/rockie_loop.py /opt/rockie-loop/rockie_loop.py
RUN chmod 755 /opt/rockie-loop/rockie_loop.py && \
    ln -sf /opt/rockie-loop/rockie_loop.py /usr/local/bin/rockie-loop

# Drop in the mcp-rockie MCP server (Phase 5 h.3) so claude/codex can
# call list_labs / get_lab / search / submit_experiment / etc. against
# platform-context.
COPY --chown=runtime:runtime overlay/multitenant/mcp-rockie /home/runtime/mcp-rockie
RUN cd /home/runtime/mcp-rockie && npm install --omit=dev && chown -R runtime:runtime /home/runtime/mcp-rockie

# Register mcp-rockie in claude + codex MCP configs so each binary
# auto-loads the tools at session start. Both CLIs read mcp.json from
# their respective ~/.claude/ and ~/.codex/ dirs.
RUN install -d -m 0755 -o runtime -g runtime /home/runtime/.claude /home/runtime/.codex && \
    printf '%s\n' '{"mcpServers":{"rockie":{"command":"node","args":["/home/runtime/mcp-rockie/server.js"]}}}' \
      | tee /home/runtime/.claude/mcp.json /home/runtime/.codex/mcp.json >/dev/null && \
    chown runtime:runtime /home/runtime/.claude/mcp.json /home/runtime/.codex/mcp.json

# A reasonable default settings.json so `claude` doesn't trip on first run.
# Tenant orchestration replaces this from settings.json.j2 at machine boot.
RUN install -m 0644 -o runtime -g runtime /dev/null /home/runtime/.claude/settings.json && \
    printf '%s\n' '{}' > /home/runtime/.claude/settings.json && \
    chown runtime:runtime /home/runtime/.claude/settings.json

# Give the runtime user ownership of /app so OpenClaw's state writes succeed.
RUN chown -R runtime:runtime /app

ENV HOME=/home/runtime
ENV PATH=/home/runtime/.local/bin:/usr/local/bin:/usr/bin:/bin
ENV MODE=byok
# OPENCLAW_PORT / OPENCLAW_BIND / OPENCLAW_HOST defaults are managed by
# overlay/multitenant/entrypoint.sh (port 18789, bind=lan, host=::). They
# previously lived here as `ENV OPENCLAW_PORT=3000 OPENCLAW_BIND=lan`,
# which silently overrode the entrypoint defaults and prevented
# platform-context's OpenClawGatewayBackend from reaching the gateway
# over Fly's IPv6-only 6PN. Leaving them unset means the entrypoint is
# the single source of truth.

USER runtime
WORKDIR /home/runtime

EXPOSE 18789
EXPOSE 7681
HEALTHCHECK --interval=3m --timeout=10s --start-period=15s --retries=3 \
  CMD node -e "fetch('http://127.0.0.1:'+(process.env.OPENCLAW_PORT||18789)+'/healthz').then((r)=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))" || exit 0

ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD []
